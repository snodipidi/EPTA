# ─────────────────────────────────────────────────────────────
# EPTA — корневой шаблон окружения для docker-compose.
# Скопируй в `.env` (он в .gitignore) и при необходимости поправь.
#
# Большинство значений имеют дефолты прямо в docker-compose.yml — этот файл нужен,
# только если хочешь что-то переопределить ИЛИ включить Python-сервисы.
# ─────────────────────────────────────────────────────────────

# ── Инфраструктура (дефолты совпадают с docker-compose) ──
# POSTGRES_USER=epta
# POSTGRES_PASSWORD=epta_dev_password
# POSTGRES_DB=epta
# CORS_ORIGINS=http://localhost:5173

# ── Python micro-services ──
# По умолчанию backend НЕ ходит в Python (переменные пусты → graceful no-op).
# Чтобы включить интеграцию:
#   1) раскомментируй URL ниже (имена — это имена сервисов в compose-сети);
#   2) подними стек с профилем python:
#        docker compose -p epta -f docker-compose.yml --profile python up -d --build
#      (или из frontend/:  npm run python)
#
# Один FastAPI-процесс на сервис, порт внутри сети — 8000.
# PY_RECOMMENDATION_URL=http://recommendation:8000
# PY_MODERATION_URL=http://moderation:8000
# PY_SEARCH_URL=http://search:8000
# PY_ANALYTICS_URL=http://analytics:8000
# PY_SERVICE_TIMEOUT_MS=4000
# PY_LOG_LEVEL=INFO
