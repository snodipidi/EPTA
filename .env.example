# ─────────────────────────────────────────────────────────────
# EPTA — корневой шаблон окружения для docker-compose.
# Скопируй в `.env` (он в .gitignore) и при необходимости поправь.
#
# Большинство значений имеют дефолты прямо в docker-compose.yml — этот файл нужен,
# только если хочешь что-то переопределить ИЛИ включить Python-сервисы.
# ─────────────────────────────────────────────────────────────

# ── Инфраструктура (дефолты совпадают с docker-compose) ──
# POSTGRES_USER=epta
# POSTGRES_PASSWORD=epta_dev_password
# POSTGRES_DB=epta
# CORS_ORIGINS=http://localhost:5173

# ── Python micro-services ──
# По умолчанию backend НЕ ходит в Python (переменные пусты → graceful no-op).
# Чтобы включить интеграцию:
#   1) раскомментируй URL ниже (имена — это имена сервисов в compose-сети);
#   2) подними стек с профилем python:
#        docker compose -p epta -f docker-compose.yml --profile python up -d --build
#      (или из frontend/:  npm run python)
#
# Один FastAPI-процесс на сервис, порт внутри сети — 8000.
# PY_RECOMMENDATION_URL=http://recommendation:8000
# PY_MODERATION_URL=http://moderation:8000
# PY_SEARCH_URL=http://search:8000
# PY_ANALYTICS_URL=http://analytics:8000
# PY_SERVICE_TIMEOUT_MS=4000
# PY_LOG_LEVEL=INFO

# ── Telegram-бот (сервис `bot`, профиль python) ──
# Каркас поднимается и без этих значений (контейнер живёт, /health работает), но
# без BOT_TOKEN бот не подключается к Telegram. Снаружи сервис на :8005.
#
# Токен бота от @BotFather. Пусто = диспетчер не запускается.
# BOT_TOKEN=123456:ABC-DEF...
# Режим получения апдейтов: polling (по умолчанию) | webhook.
# BOT_MODE=polling
# Для webhook: публичный базовый URL (без пути) и секрет проверки заголовка.
# BOT_WEBHOOK_URL=https://bot.example.com
# BOT_WEBHOOK_SECRET=
#
# Pyrogram-юзербот (опционально, доп. возможности сверх Bot API). Креды с my.telegram.org.
# Пусто = юзербот не поднимается.
# PYROGRAM_API_ID=0
# PYROGRAM_API_HASH=
# PYROGRAM_SESSION_STRING=
#
# Связь с backend: исходящие вызовы бота идут на этот URL (внутри сети — backend:3000).
# BACKEND_API_URL=http://backend:3000/api
# Общий секрет для внутренних вызовов backend → бот (если включишь приватные маршруты).
# INTERNAL_API_TOKEN=
