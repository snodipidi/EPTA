# ─────────────────────────────────────────────────────────────
# EPTA backend — environment template. Copy to `.env` and adjust.
# ─────────────────────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3000
# Comma-separated list of allowed origins for CORS (the Vite frontend dev server)
CORS_ORIGINS=http://localhost:5173

# Database (PostgreSQL)
# When running the backend INSIDE docker-compose, host is `postgres`.
# When running it on the host against the compose DB, host is `localhost`.
POSTGRES_USER=epta
POSTGRES_PASSWORD=epta_dev_password
POSTGRES_DB=epta
DATABASE_URL=postgresql://epta:epta_dev_password@localhost:5432/epta?schema=public

# Redis (cache, BullMQ, Socket.IO adapter)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT — generate strong secrets for production (e.g. `openssl rand -hex 32`)
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_ACCESS_TTL=900s
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_REFRESH_TTL=30d

# Rate limiting (global throttler)
THROTTLE_TTL=60
THROTTLE_LIMIT=120

# Media / object storage (MinIO in dev, S3-compatible in prod).
# Not required until the media module is exercised.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=epta-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
# Public base URL used to build media URLs returned to clients
MEDIA_PUBLIC_URL=http://localhost:9000/epta-media

# Python micro-services (каркас сервисов — в ./python-services, профиль compose `python`).
# Пусто = клиент молчит (graceful no-op, без таймаутов). Чтобы включить — задай URL
# (в compose-сети: http://recommendation:8000 и т.д.) и подними `--profile python`.
# См. python-services/README.md и корневой .env.example.
PY_RECOMMENDATION_URL=
PY_MODERATION_URL=
PY_ANALYTICS_URL=
PY_SEARCH_URL=
PY_SERVICE_TIMEOUT_MS=4000
